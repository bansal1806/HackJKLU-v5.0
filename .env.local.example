# ─── Cashfree Payment Gateway ─────────────────────────────────────────────────
CASHFREE_APP_ID=your_app_id_here
CASHFREE_SECRET_KEY=your_secret_key_here
CASHFREE_ENV=TEST        # Change to PROD before going live

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hackjklu?retryWrites=true&w=majority

# ─── Resend (Email confirmations — optional) ──────────────────────────────────
RESEND_API_KEY=re_your_key_here

# ─── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # Change to your Vercel URL in production
